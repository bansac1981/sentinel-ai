{{- $pctx := . -}}
{{- if .IsHome -}}{{ $pctx = .Site }}{{- end -}}
{{- $pages := slice -}}
{{- if or $.IsHome $.IsSection -}}
  {{- $pages = where $pctx.RegularPages "Type" "posts" -}}
{{- else -}}
  {{- $pages = $pctx.Pages -}}
{{- end -}}
{{- $pages = $pages | first 20 -}}
{{- printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
  <channel>
    <title>{{ if eq .Title .Site.Title }}{{ .Site.Title }} — AI Threat Intelligence{{ else }}{{ .Title }} | {{ .Site.Title }}{{ end }}</title>
    <link>{{ .Permalink }}</link>
    <description>{{ if .IsHome }}Real-time AI security intelligence — adversarial ML, LLM vulnerabilities, and supply chain threats mapped to MITRE ATLAS and OWASP LLM Top 10.{{ else }}{{ .Title }}{{ end }}</description>
    <generator>Hugo</generator>
    <language>en-us</language>
    <copyright>{{ .Site.Copyright }}</copyright>
    <lastBuildDate>{{ now.Format "Mon, 02 Jan 2006 15:04:05 -0700" }}</lastBuildDate>
    <atom:link href="{{ "index.xml" | absURL }}" rel="self" type="application/rss+xml" />
    {{ range $pages }}
    <item>
      <title>{{ .Title | html }}</title>
      <link>{{ .Permalink }}</link>
      <pubDate>{{ .Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" }}</pubDate>
      <guid>{{ .Permalink }}</guid>
      {{ with .Params.threat_level }}<category>Threat Level: {{ . }}</category>{{ end }}
      {{ range .Params.categories }}<category>{{ . }}</category>{{ end }}
      {{ range .Params.mitre_techniques }}<category>{{ . }}</category>{{ end }}
      <description>{{ with .Params.summary }}{{ . | html }}{{ else }}{{ .Summary | html }}{{ end }}</description>
    </item>
    {{ end }}
  </channel>
</rss>
