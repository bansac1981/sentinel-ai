{{- $posts := where .Site.RegularPages "Type" "posts" -}}
{{- $posts = where $posts "Params.draft" "ne" true -}}
[
  {{- range $i, $p := $posts -}}
  {{- if $i }},{{ end }}
  {
    "title": {{ $p.Title | jsonify }},
    "url": {{ $p.RelPermalink | jsonify }},
    "summary": {{ $p.Params.summary | default $p.Summary | jsonify }},
    "date": {{ $p.Date.Format "2006-01-02" | jsonify }},
    "source": {{ $p.Params.source | default "" | jsonify }},
    "relevance_score": {{ $p.Params.relevance_score | default 0 }},
    "threat_level": {{ $p.Params.threat_level | default "" | jsonify }},
    "categories": {{ $p.Params.categories | jsonify }},
    "tags": {{ $p.Params.tags | jsonify }},
    "mitre_techniques": {{ $p.Params.mitre_techniques | jsonify }},
    "owasp_categories": {{ $p.Params.owasp_categories | jsonify }}
  }
  {{- end }}
]
