# ── SENTINEL AI Pipeline — Environment Variables ──
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# Anthropic API key — get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Claude model to use for scoring and analysis
# Recommended: claude-sonnet-4-6 (best quality/cost balance)
CLAUDE_MODEL=claude-sonnet-4-6

# Relevance score threshold (0.0–10.0). Articles below this are discarded.
RELEVANCE_THRESHOLD=6.0

# Path to the Hugo content/posts directory (relative to repo root)
HUGO_POSTS_DIR=hugo-site/content/posts

# Path to the seen-URLs cache file (prevents reprocessing articles)
SEEN_URLS_FILE=seen_urls.json

# Max articles to process per pipeline run (0 = no limit)
MAX_ARTICLES_PER_RUN=20

# Whether to fetch full article content for richer analysis (true/false)
# Fetching full content produces better MITRE/OWASP mapping but is slower
FETCH_FULL_CONTENT=true

# Request timeout in seconds for fetching article content
FETCH_TIMEOUT=10
